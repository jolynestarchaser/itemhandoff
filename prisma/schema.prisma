// Define database connection via the `DATABASE_URL` env var
datasource db {
  provider = "postgresql"
}

// Define custom output path for generated Prisma Client
generator client {
  provider = "prisma-client-js"
}

model HandoffRecord {
  id           String   @id @default(cuid())
  qrData       String   // e.g., "Apix Round A001"
  productName  String   // Parsed from QR (e.g., "Apix Round")
  productId    String   // Parsed from QR (e.g., "A001")
  department   String
  createdAt    DateTime @default(now())
}
